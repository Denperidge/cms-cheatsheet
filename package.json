{
  "name": "cms-cheatsheet",
  "description": "Create an easily searchable cheatsheet for your code or anything",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "eleventy --serve",
    "build": "eleventy",
    "data": "pnpm directus-to-data --collection-output src/_data/{{collectionName}}.json -c DenperidgeCheatsheet -c DenperidgeCheatsheet_DenperidgeCheatsheet",
    "data:pull": "pnpm data && pnpm data:pull:schema",
    "data:pull:schema": "pnpm directus-to-data --backup-schema .directus.schema.json --collection-output NO_WRITE -c DenperidgeCheatsheet -c DenperidgeCheatsheet_DenperidgeCheatsheet"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-pug": "^1.0.0",
    "@grimlink/eleventy-plugin-sass": "^1.0.3",
    "@picocss/pico": "^2.1.1",
    "catppuccin-prismjs": "github:catppuccin/prismjs",
    "directus-to-data": "^0.8.1",
    "eleventy-auto-cache-buster": "^0.9.2",
    "eleventy-favicons": "^1.0.3",
    "fuse.js": "^7.3.0",
    "jquery": "^3.7.1",
    "markdown-it": "^14.1.1",
    "prismjs": "^1.30.0",
    "sass": "^1.99.0"
  },
  "pnpm": {
    "overrides": {
      "chokidar": "^5.0.0"
    }
  },
  "author": "Denperidge",
  "repository": "https://github.com/Denperidge/cms-cheatsheet.git"
}
